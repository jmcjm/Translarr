@inject LibraryApiService LibraryApiService
@using Microsoft.AspNetCore.SignalR.Client
@using Translarr.Frontend.HavitWebApp.Auth
@using Translarr.Core.Api.Models
@using Translarr.Frontend.HavitWebApp.Helpers
@inject AuthCookieHolder AuthCookieHolder
@inject IConfiguration Configuration
@inject IHttpMessageHandlerFactory HandlerFactory
@implements IAsyncDisposable

<nav class="nav flex-column">
    <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
        <i class="bi bi-speedometer2 me-2"></i>
        Dashboard
    </NavLink>

    <div class="nav-item px-3">
        <NavLink class="nav-link" href="library/all" Match="NavLinkMatch.All">
            <span class="bi bi-book-half" aria-hidden="true"></span> All Entries
        </NavLink>
    </div>

    @if (_libraries != null)
    {
        @foreach (var library in _libraries)
        {
            var slug = SlugHelper.ToSlug(library);
            <div class="nav-item px-3 ps-4">
                <NavLink class="nav-link" href="@($"library/{slug}")" Match="NavLinkMatch.Prefix">
                    <span class="bi bi-folder" aria-hidden="true"></span> @library
                </NavLink>
            </div>
        }
    }

    <NavLink class="nav-link" href="/settings" Match="NavLinkMatch.Prefix">
        <i class="bi bi-gear me-2"></i>
        Settings
    </NavLink>
    <NavLink class="nav-link" href="/stats" Match="NavLinkMatch.Prefix">
        <i class="bi bi-bar-chart me-2"></i>
        Statistics
    </NavLink>
</nav>

<style>
    .nav-link {
        color: var(--bs-body-color);
        padding: 0.75rem 1rem;
        border-radius: 0;
        transition: background-color 0.2s ease;
    }

    .nav-link:hover {
        background-color: var(--bs-primary-bg-subtle);
    }

    .nav-link.active {
        background-color: var(--bs-primary);
        color: white;
        font-weight: 500;
    }

    .nav-link i {
        font-size: 1.1rem;
    }
</style>

@code {
    private List<string>? _libraries;
    private HubConnection? _hubConnection;

    protected override async Task OnInitializedAsync()
    {
        await LoadLibraries();

        var apiBaseUrl = Configuration["ApiBaseUrl"] ?? "https+http://Translarr-Api";

        _hubConnection = new HubConnectionBuilder()
            .WithUrl($"{apiBaseUrl}/hubs/progress", options =>
            {
                options.AccessTokenProvider = () => Task.FromResult(AuthCookieHolder.CookieValue);
                options.HttpMessageHandlerFactory = _ => HandlerFactory.CreateHandler("TranslarrApi");
            })
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<ScanStatus>("ScanProgress", async status =>
        {
            if (!status.IsRunning && status.Result is not null)
            {
                await InvokeAsync(async () =>
                {
                    await LoadLibraries();
                    StateHasChanged();
                });
            }
        });

        try
        {
            await _hubConnection.StartAsync();
        }
        catch
        {
            // Hub connection failed — libraries still work from initial load
        }
    }

    private async Task LoadLibraries()
    {
        try
        {
            _libraries = await LibraryApiService.GetLibrariesAsync();
        }
        catch
        {
            _libraries = null;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
            await _hubConnection.DisposeAsync();
    }
}
