@page "/"
@inject StatsApiService StatsService
@inject LibraryApiService LibraryService
@inject TranslationApiService TranslationService
@inject IHxMessengerService Messenger
@using Microsoft.AspNetCore.SignalR.Client
@using Translarr.Frontend.HavitWebApp.Auth
@inject AuthCookieHolder AuthCookieHolder
@inject IConfiguration Configuration
@inject IHttpMessageHandlerFactory HandlerFactory
@implements IAsyncDisposable

<PageTitle>Dashboard - Translarr</PageTitle>

<h1 class="mb-4">Dashboard</h1>

@if (_isLoading)
{
    <div class="d-flex justify-content-center my-4">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}

@if (_stats != null)
{
    <!-- Statistics Cards -->
    <div class="row row-cols-1 row-cols-sm-3 row-cols-lg-5 g-3 mb-4">
        <div class="col">
            <HxCard>
                <BodyTemplate>
                    <h2 class="display-6">@_stats.TotalFiles</h2>
                    <p class="text-muted mb-0">Total Files</p>
                </BodyTemplate>
            </HxCard>
        </div>

        <div class="col">
            <HxCard CssClass="border-success">
                <BodyTemplate>
                    <h2 class="display-6 text-success">@_stats.ProcessedFiles</h2>
                    <p class="text-muted mb-0">Processed</p>
                </BodyTemplate>
            </HxCard>
        </div>

        <div class="col">
            <HxCard CssClass="border-warning">
                <BodyTemplate>
                    <h2 class="display-6 text-warning">@_stats.WantedFiles</h2>
                    <p class="text-muted mb-0">Waiting</p>
                </BodyTemplate>
            </HxCard>
        </div>

        <div class="col">
            <HxCard CssClass="border-danger">
                <BodyTemplate>
                    <h2 class="display-6 text-danger">@_stats.ErrorFiles</h2>
                    <p class="text-muted mb-0">Errors</p>
                </BodyTemplate>
            </HxCard>
        </div>

        <div class="col">
            <HxCard CssClass="border-info">
                <BodyTemplate>
                    <h2 class="display-6 text-info">@_stats.BitmapFiles</h2>
                    <p class="text-muted mb-0">Bitmap</p>
                </BodyTemplate>
            </HxCard>
        </div>
    </div>

    <!-- Actions Card -->
    <div class="row g-3 mb-4">
        <div class="col-12">
            <HxCard>
                <HeaderTemplate>
                    <h5 class="mb-0">Actions</h5>
                </HeaderTemplate>
                <BodyTemplate>
                    <div class="d-flex gap-3 flex-wrap">
                        <HxButton Color="ThemeColor.Primary"
                                  OnClick="ScanLibrary"
                                  Enabled="!_isScanning">
                            Scan Library
                        </HxButton>

                        @if (_translationStatus is { IsRunning: true })
                        {
                            <HxButton Color="ThemeColor.Danger"
                                      OnClick="CancelTranslation"
                                      Enabled="!_isCancelling">
                                <i class="bi bi-stop-circle me-2"></i>
                                Stop Translation
                            </HxButton>
                        }
                        else
                        {
                            <HxButton Color="ThemeColor.Secondary"
                                      OnClick="StartTranslation"
                                      Enabled="!_isTranslating && _stats.WantedFiles > 0">
                                <i class="bi bi-translate me-2"></i>
                                Start Translation
                            </HxButton>
                        }

                        @if (_bitmapTranslationStatus is { IsRunning: true })
                        {
                            <HxButton Color="ThemeColor.Danger"
                                      OnClick="CancelBitmapTranslation"
                                      Enabled="!_isCancellingBitmap">
                                <i class="bi bi-stop-circle me-2"></i>
                                Stop Bitmap OCR
                            </HxButton>
                        }
                        else
                        {
                            <HxButton Color="ThemeColor.Info"
                                      OnClick="StartBitmapTranslation"
                                      Enabled="!_isTranslatingBitmap && _stats.BitmapFiles > 0">
                                <i class="bi bi-image me-2"></i>
                                Start Bitmap OCR Translation
                            </HxButton>
                        }
                    </div>
                </BodyTemplate>
            </HxCard>
        </div>
    </div>

    <!-- Scan Progress Card -->
    @if (_scanStatus is { IsRunning: true })
    {
        <div class="row g-3 mb-4">
            <div class="col-12">
                <HxCard CssClass="border-primary">
                    <HeaderTemplate>
                        <h5 class="mb-0">Library Scan Progress</h5>
                    </HeaderTemplate>
                    <BodyTemplate>
                        <p class="mb-2">@_scanStatus.Progress</p>
                        <div class="progress">
                            <div class="progress-bar progress-bar-striped progress-bar-animated"
                                 role="progressbar"
                                 style="width: 100%"></div>
                        </div>
                    </BodyTemplate>
                </HxCard>
            </div>
        </div>
    }

    <!-- Translation Progress Card -->
    @if (_translationStatus is { IsRunning: true })
    {
        <div class="row g-3 mb-4">
            <div class="col-12">
                <HxCard CssClass="border-info">
                    <HeaderTemplate>
                        <h5 class="mb-0">Translation Progress</h5>
                    </HeaderTemplate>
                    <BodyTemplate>
                        <p class="mb-2">@_translationStatus.Progress</p>
                        <div class="progress">
                            <div class="progress-bar progress-bar-striped progress-bar-animated"
                                 role="progressbar"
                                 style="width: 100%"></div>
                        </div>
                    </BodyTemplate>
                </HxCard>
            </div>
        </div>
    }

    <!-- Bitmap OCR Progress Card -->
    @if (_bitmapTranslationStatus is { IsRunning: true })
    {
        <div class="row g-3 mb-4">
            <div class="col-12">
                <HxCard CssClass="border-info">
                    <HeaderTemplate>
                        <h5 class="mb-0">Bitmap OCR Progress</h5>
                    </HeaderTemplate>
                    <BodyTemplate>
                        <p class="mb-2">@_bitmapTranslationStatus.Progress</p>
                        @{
                            var batchPercent = _bitmapTranslationStatus.TotalBatches > 0
                                ? (int)(_bitmapTranslationStatus.CurrentBatch * 100.0 / _bitmapTranslationStatus.TotalBatches)
                                : 0;
                        }
                        <div class="progress">
                            <div class="progress-bar progress-bar-striped progress-bar-animated bg-info"
                                 role="progressbar"
                                 style="width: @(batchPercent > 0 ? batchPercent : 100)%"
                                 aria-valuenow="@batchPercent"
                                 aria-valuemin="0"
                                 aria-valuemax="100">
                                @if (batchPercent > 0)
                                {
                                    @($"{batchPercent}%")
                                }
                            </div>
                        </div>
                    </BodyTemplate>
                </HxCard>
            </div>
        </div>
    }

    <!-- Last Scanned Alert -->
    @if (_stats.LastScanned.HasValue)
    {
        <div class="alert alert-info" role="alert">
            <i class="bi bi-info-circle me-2"></i>
            Last scan: @_stats.LastScanned.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")
        </div>
    }
}

@code {
    private LibraryStats? _stats;
    private TranslationStatus? _translationStatus;
    private TranslationStatus? _bitmapTranslationStatus;
    private ScanStatus? _scanStatus;
    private bool _isLoading = true;
    private bool _isScanning;
    private bool _isTranslating;
    private bool _isCancelling;
    private bool _isTranslatingBitmap;
    private bool _isCancellingBitmap;
    private HubConnection? _hubConnection;
    private CancellationTokenSource? _hubCts;

    protected override async Task OnInitializedAsync()
    {
        await LoadStats();

        var apiBaseUrl = Configuration["ApiBaseUrl"] ?? "https+http://Translarr-Api";
        _hubCts = new CancellationTokenSource();

        _hubConnection = new HubConnectionBuilder()
            .WithUrl($"{apiBaseUrl}/hubs/progress", options =>
            {
                options.AccessTokenProvider = () => Task.FromResult(AuthCookieHolder.CookieValue);
                options.HttpMessageHandlerFactory = _ => HandlerFactory.CreateHandler("TranslarrApi");
            })
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<TranslationStatus>("TranslationProgress", async status =>
        {
            var wasRunning = _translationStatus?.IsRunning ?? false;
            _translationStatus = status;
            if (wasRunning && !status.IsRunning && status.Result is not null)
                await InvokeAsync(LoadStats);
            await InvokeAsync(StateHasChanged);
        });

        _hubConnection.On<TranslationStatus>("BitmapProgress", async status =>
        {
            var wasRunning = _bitmapTranslationStatus?.IsRunning ?? false;
            _bitmapTranslationStatus = status;
            if (wasRunning && !status.IsRunning && status.Result is not null)
                await InvokeAsync(LoadStats);
            await InvokeAsync(StateHasChanged);
        });

        _hubConnection.On<ScanStatus>("ScanProgress", async status =>
        {
            var wasRunning = _scanStatus?.IsRunning ?? false;
            _scanStatus = status;
            if (wasRunning && !status.IsRunning && status.Result is not null)
                await InvokeAsync(LoadStats);
            await InvokeAsync(StateHasChanged);
        });

        _hubConnection.Reconnected += async _ => await LoadCurrentStatus();

        try
        {
            await _hubConnection.StartAsync(_hubCts.Token);
            await LoadCurrentStatus();
        }
        catch (OperationCanceledException)
        {
            // Component disposed during connection — ignore
        }
    }

    private async Task LoadStats()
    {
        try
        {
            _isLoading = true;
            _stats = await StatsService.GetLibraryStatsAsync();
        }
        catch (Exception ex)
        {
            Messenger.AddError($"Error loading stats: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadCurrentStatus()
    {
        try
        {
            _translationStatus = await TranslationService.GetTranslationStatusAsync();
            _bitmapTranslationStatus = await TranslationService.GetBitmapTranslationStatusAsync();
            _scanStatus = await LibraryService.GetScanStatusAsync();
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            // Ignore errors during status fetch
        }
    }

    private async Task ScanLibrary()
    {
        try
        {
            _isScanning = true;
            var success = await LibraryService.StartScanAsync();

            if (success)
            {
                Messenger.AddInformation("Library scan started");
            }
            else
            {
                Messenger.AddError("Failed to start scan");
            }
        }
        catch (Exception ex)
        {
            Messenger.AddError($"Error starting scan: {ex.Message}");
        }
        finally
        {
            _isScanning = false;
        }
    }

    private async Task StartTranslation()
    {
        try
        {
            _isTranslating = true;
            var success = await TranslationService.StartTranslationAsync(100);

            if (success)
            {
                Messenger.AddInformation("Translation started");
            }
            else
            {
                Messenger.AddError("Failed to start translation");
            }
        }
        catch (Exception ex)
        {
            Messenger.AddError($"Error starting translation: {ex.Message}");
        }
        finally
        {
            _isTranslating = false;
        }
    }

    private async Task CancelTranslation()
    {
        try
        {
            _isCancelling = true;
            var success = await TranslationService.CancelTranslationAsync();

            if (success)
            {
                Messenger.AddInformation("Translation cancellation requested");
            }
            else
            {
                Messenger.AddError("Failed to cancel translation");
            }
        }
        catch (Exception ex)
        {
            Messenger.AddError($"Error cancelling translation: {ex.Message}");
        }
        finally
        {
            _isCancelling = false;
        }
    }


    private async Task StartBitmapTranslation()
    {
        try
        {
            _isTranslatingBitmap = true;
            var success = await TranslationService.StartBitmapTranslationAsync(100);

            if (success)
            {
                Messenger.AddInformation("Bitmap OCR translation started");
            }
            else
            {
                Messenger.AddError("Failed to start bitmap OCR translation");
            }
        }
        catch (Exception ex)
        {
            Messenger.AddError($"Error starting bitmap OCR translation: {ex.Message}");
        }
        finally
        {
            _isTranslatingBitmap = false;
        }
    }

    private async Task CancelBitmapTranslation()
    {
        try
        {
            _isCancellingBitmap = true;
            var success = await TranslationService.CancelBitmapTranslationAsync();

            if (success)
            {
                Messenger.AddInformation("Bitmap OCR translation cancellation requested");
            }
            else
            {
                Messenger.AddError("Failed to cancel bitmap OCR translation");
            }
        }
        catch (Exception ex)
        {
            Messenger.AddError($"Error cancelling bitmap OCR translation: {ex.Message}");
        }
        finally
        {
            _isCancellingBitmap = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubCts is not null)
        {
            await _hubCts.CancelAsync();
            _hubCts.Dispose();
        }

        if (_hubConnection is not null)
            await _hubConnection.DisposeAsync();
    }
}
